# ============================================================
# BrandOS — Environment Variables
# Copy this file to .env.local for local dev.
# In Vercel: add each variable in Project Settings > Environment Variables.
# NEVER commit .env.local or any file with real keys.
# ============================================================

# Supabase — from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Claude API — from console.anthropic.com
# Keep this server-side only (no NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY=sk-ant-your-key-here
